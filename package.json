{
  "name": "todo-sync-flow",
  "version": "1.0.0",
  "description": "Converts TODO/FIXME/HACK comments into GitHub issues with full lifecycle management",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/main.ts -o dist --license licenses.txt",
